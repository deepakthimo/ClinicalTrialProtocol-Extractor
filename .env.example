# =============================================================
# lilly-pdf-extractor-agent — Environment Variables
# =============================================================
# Copy this file to .env and fill in the values below.
# The Dockerfile bakes .env into the image at build time.
# ⚠  Never commit .env (it contains secrets) — .gitignore already excludes it.
# =============================================================


# -------------------------------------------------------------
# Cortex LLM — Authentication (OAuth2 / client-credentials)
# Used by: agents/cortex_langchain.py
# -------------------------------------------------------------
CORTEX_CLIENT_ID=
CORTEX_CLIENT_SECRET=
CORTEX_AUTHORITY=
CORTEX_SCOPE=
CORTEX_BASE_URL=https://gateway.apim.lilly.com/cortex/cortex-openai

# Use AWS IAM auth for Cortex instead of OAuth2 (true/false)
USE_AWS_AUTH=false


# -------------------------------------------------------------
# Cortex LLM — Direct API auth (alternative to OAuth2)
# Used by: agents/cortex_llm_config.py, manage_cortex_agent/manage_agents.py
# Set either CORTEX_API_KEY or CORTEX_COOKIE (not both needed)
# -------------------------------------------------------------
CORTEX_API_KEY=
CORTEX_COOKIE=


# -------------------------------------------------------------
# Cortex Agent Management
# Used by: manage_cortex_agent/manage_agents.py
# -------------------------------------------------------------
OWNER_EMAIL=


# -------------------------------------------------------------
# Cloud Storage — AWS S3 (optional)
# If set, output JSON is uploaded to S3. Requires boto3 + AWS credentials.
# boto3 will automatically pick up AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# from environment if not using IAM roles.
# Used by: utils/cloud_storage.py
# -------------------------------------------------------------
AWS_S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=


# -------------------------------------------------------------
# Cloud Storage — Google Cloud Storage (optional)
# If set, output JSON is uploaded to GCS.
# GOOGLE_APPLICATION_CREDENTIALS must point to your service-account key file.
# Inside the container it lives at /app/gcp-service-account-key.json
# Used by: utils/cloud_storage.py
# -------------------------------------------------------------
GCP_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-service-account-key.json


# -------------------------------------------------------------
# LLM Timeout & Retry (all have defaults — override only if needed)
# Used by: core/config.py
# -------------------------------------------------------------
LLM_TIMEOUT_SECONDS=180
LLM_TIMEOUT_MULTIMODAL_SECONDS=240
LLM_RETRY_ATTEMPTS=4


# -------------------------------------------------------------
# Concurrency & Throttle (tuning knobs — defaults shown)
# Used by: core/config.py
# -------------------------------------------------------------
MAX_CONCURRENT_PDFS=1
MAX_CONCURRENT_SECTIONS=3
COPY_HEADROOM=2
PAGE_THROTTLE_SECONDS=3


# -------------------------------------------------------------
# Page-level retry
# Used by: core/config.py
# -------------------------------------------------------------
PAGE_RETRY_ATTEMPTS=2
PAGE_RETRY_BACKOFF_SECONDS=60


# -------------------------------------------------------------
# Logging / Debug
# Used by: core/config.py, core/logger.py
# -------------------------------------------------------------
DEBUG=false
DEBUG_AGENTS=false
